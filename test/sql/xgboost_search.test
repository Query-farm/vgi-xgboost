# name: test/sql/xgboost_search.test
# description: Cross-validated hyperparameter search (grid_search / randomized_search)
# group: [vgi_xgboost]

require-env VGI_XGBOOST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'xgboost' AS xgboost (TYPE vgi, LOCATION '${VGI_XGBOOST_WORKER}');

statement ok
CREATE TEMP VIEW iris_xy AS
  SELECT sample_id, sepal_length_cm, sepal_width_cm, petal_length_cm, petal_width_cm, target
  FROM xgboost.iris();

# grid_search returns one row per combination (2 x 2 = 4)
query I
SELECT count(*) FROM xgboost.grid_search((SELECT * FROM iris_xy),
  target := 'target', id := 'sample_id',
  estimator := union_value(xgb_classifier := {'n_estimators': [30, 60], 'max_depth': [2, 4]}));
----
4

# exactly one row (the best) carries the refit model BLOB
query I
SELECT count(*) FROM xgboost.grid_search((SELECT * FROM iris_xy),
  target := 'target', id := 'sample_id',
  estimator := union_value(xgb_classifier := {'n_estimators': [30, 60], 'max_depth': [2, 4]}))
WHERE model IS NOT NULL;
----
1

# the best mean test score is high on iris
query I
SELECT max(mean_test_score) > 0.9 FROM xgboost.grid_search((SELECT * FROM iris_xy),
  target := 'target', id := 'sample_id',
  estimator := union_value(xgb_classifier := {'n_estimators': [30, 60], 'max_depth': [2, 4]}));
----
true

# the rank-1 model BLOB predicts when fed back to predict()
statement ok
SET VARIABLE gs_model = (SELECT model FROM xgboost.grid_search((SELECT * FROM iris_xy),
  target := 'target', id := 'sample_id',
  estimator := union_value(xgb_classifier := {'n_estimators': [40, 80]})) WHERE model IS NOT NULL);

query I
SELECT count(*) FROM xgboost.predict(
  (SELECT sample_id, sepal_length_cm, sepal_width_cm, petal_length_cm, petal_width_cm FROM xgboost.iris()),
  model := getvariable('gs_model'), id := 'sample_id');
----
150

# grid_search can persist the best model to the registry
statement ok
SELECT 1 FROM xgboost.grid_search((SELECT * FROM iris_xy),
  target := 'target', id := 'sample_id', model_name := 'gs_best',
  estimator := union_value(xgb_classifier := {'n_estimators': [40, 80]})) WHERE model IS NOT NULL;

query I
SELECT count(*) FROM xgboost.model_info('gs_best');
----
1

# randomized_search samples n_iter combinations (capped at the grid size)
query I
SELECT count(*) FROM xgboost.randomized_search((SELECT * FROM iris_xy),
  target := 'target', id := 'sample_id', n_iter := 3,
  estimator := union_value(xgb_classifier := {'n_estimators': [30, 60, 90], 'max_depth': [2, 4, 6]}));
----
3

# n_iter beyond the grid size is clamped to the number of combinations (2)
query I
SELECT count(*) FROM xgboost.randomized_search((SELECT * FROM iris_xy),
  target := 'target', id := 'sample_id', n_iter := 50,
  estimator := union_value(xgb_classifier := {'n_estimators': [30, 60]}));
----
2

# a missing target is rejected at bind
statement error
SELECT * FROM xgboost.grid_search((SELECT * FROM iris_xy),
  estimator := union_value(xgb_classifier := {'n_estimators': [30, 60]}));
----
requires 'target'

statement ok
SELECT * FROM xgboost.drop_model('gs_best');

statement ok
DETACH xgboost;
